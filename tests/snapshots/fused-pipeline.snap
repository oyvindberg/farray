    val src0: FBase = ints.$asInstanceOf$[ints & FArray[Int]].asInstanceOf[FBase]
    val n0: Int = src0.length
    val cap: Int = n0
    val out: Array[Int] = new Array[Int](cap)
    var o: Int = 0
    val s: FBase = src0
    val len: Int = s.length
    if (s.isInstanceOf[IntArr]) {
      val a: Array[Int] = s.asInstanceOf[IntArr].arr
      var i: Int = 0
      while (i.<(len)) {
        val v: Int = a.apply(i)
        v match {
          case x if `xв‚‚`.>(2) =>
            {
              out.update(o, `xв‚‚`)
              o = o.+(1)
            }
          case _ =>
            ()
        }
        i = i.+(1)
      }
    } else {
      var `iв‚‚`: Int = 0
      while (`iв‚‚`.<(len)) {
        val `vв‚‚`: Int = FArrayOps.intAt(s, `iв‚‚`)
        `vв‚‚` match {
          case x if `xв‚ѓ`.>(2) =>
            {
              out.update(o, `xв‚ѓ`)
              o = o.+(1)
            }
          case _ =>
            ()
        }
        `iв‚‚` = `iв‚‚`.+(1)
      }
    }
    if (o.==(0)) (IntArr.EMPTY: FBase) else if (o.==(cap)) new IntArr(out, o) else new IntArr(java.util.Arrays.copyOf(out, o), o)
  }.asInstanceOf[FArray[Int]]: FArray[Int])
}
